---
import { getLocaleFromUrl, useTranslations } from "@/i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark py-20 px-6 relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">
          {t.contact.label}
        </p>
        <h2 class="text-5xl md:text-6xl font-bold text-white mb-10">Contactos</h2>
        <ul class="space-y-3 text-gray-400 text-sm">
          <li>{t.footer.address}</li>
          <li>
            <a href={`mailto:${t.footer.email}`} class="hover:text-primary transition-colors">
              {t.footer.email}
            </a>
          </li>
          <li>
            <a href={`tel:${t.footer.phone}`} class="hover:text-primary transition-colors">
              {t.footer.phone}
            </a>
          </li>
        </ul>
      </div>

      <div class="flex flex-col gap-4 md:items-end">
        <ul class="flex gap-6 text-gray-400 text-sm">
          <li><a href="#home" class="hover:text-white transition-colors">{t.nav.home}</a></li>
          <li><a href="#sobre" class="hover:text-white transition-colors">{t.nav.about}</a></li>
          <li><a href="#servicos" class="hover:text-white transition-colors">{t.nav.services}</a></li>
          <li><a href="#projetos" class="hover:text-white transition-colors">{t.nav.projects}</a></li>
          <li><a href="#contato" class="hover:text-white transition-colors">{t.nav.contact}</a></li>
        </ul>
        <div class="flex gap-4">
          <a href="#" class="text-gray-400 hover:text-white transition-colors text-sm">Instagram</a>
          <a href="#" class="text-gray-400 hover:text-white transition-colors text-sm">LinkedIn</a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800">
      <p class="text-gray-600 text-xs">
        &copy; {currentYear} arqmag. {t.footer.rights}.
      </p>
    </div>
  </div>

  <img
    src="/logo/Logo H_white_arqmag.png"
    alt=""
    aria-hidden="true"
    class="absolute right-0 bottom-0 w-1/2 md:w-2/5 opacity-5 pointer-events-none select-none"
  />
</footer>
