---
import { getLocaleFromUrl, useTranslations } from "@/i18n";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-2">
        <a href={locale === "en" ? "/" : `/${locale}`} class="text-3xl font-bold text-primary">
          ARQ
        </a>
        <p class="mt-4 text-gray-400 max-w-md">
          {locale === "pt"
            ? "Escritório de arquitetura dedicado à criação de espaços que inspiram e transformam vidas."
            : "Architecture firm dedicated to creating spaces that inspire and transform lives."}
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-primary">Menu</h4>
        <ul class="space-y-2 text-gray-400">
          <li><a href={locale === "en" ? "/" : `/${locale}`} class="hover:text-white transition-colors">{t.nav.home}</a></li>
          <li><a href={`/${locale}/projetos`} class="hover:text-white transition-colors">{t.nav.projects}</a></li>
          <li><a href={`/${locale}/sobre`} class="hover:text-white transition-colors">{t.nav.about}</a></li>
          <li><a href={`/${locale}/contato`} class="hover:text-white transition-colors">{t.nav.contact}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-primary">{locale === "pt" ? "Contacto" : "Contact"}</h4>
        <ul class="space-y-2 text-gray-400">
          <li>{t.footer.address}</li>
          <li>info@arquitetura.pt</li>
          <li>+351 21 123 4567</li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">
        &copy; {currentYear} ARQ. {t.footer.rights}.
      </p>
      <div class="flex gap-4">
        <a href="#" class="text-gray-400 hover:text-white transition-colors">Instagram</a>
        <a href="#" class="text-gray-400 hover:text-white transition-colors">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
