---
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import MobileMenu from "@/components/react/MobileMenu";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const navLinks = [
  { href: "#home", label: t.nav.home },
  { href: "#sobre", label: t.nav.about },
  { href: "#servicos", label: t.nav.services },
  { href: "#projetos", label: t.nav.projects },
  { href: "#contato", label: t.nav.contact },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-transparent">
  <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href={locale === "en" ? "/en" : "/pt"} class="flex-shrink-0">
      <img
        src="/logo/Logo H_white_arqmag.png"
        alt="arqmag"
        class="h-8 w-auto"
      />
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            data-section={link.href.slice(1)}
            class="text-xs font-semibold tracking-widest transition-colors hover:text-primary text-white/80"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-3">
      <a
        href={locale === "pt" ? "/en" : "/pt"}
        class="flex items-center gap-1 transition-opacity hover:opacity-80"
        title={locale === "pt" ? "English" : "Português"}
      >
        <img
          src={locale === "pt" ? "/logo/united-kingdom.png" : "/logo/portugal.png"}
          alt={locale === "pt" ? "EN" : "PT"}
          class="w-6 h-6 rounded-full object-cover"
        />
      </a>
    </div>

    <div class="md:hidden">
      <MobileMenu client:load links={navLinks} locale={locale} />
    </div>
  </nav>
</header>

<script>
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-section]");

  function setActive(id: string) {
    for (const link of navLinks) {
      const isActive = link.dataset.section === id;
      link.classList.toggle("text-primary", isActive);
      link.classList.toggle("text-white/80", !isActive);
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      }
    },
    { rootMargin: "-30% 0px -60% 0px", threshold: 0 }
  );

  for (const section of sections) {
    observer.observe(section);
  }

  if (window.scrollY === 0) setActive("home");
</script>
