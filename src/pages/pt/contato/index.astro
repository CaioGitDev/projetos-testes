---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import ContactForm from "@/components/react/ContactForm";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout title={t.contact.title}>
  <section class="pt-20 pb-12 px-6 bg-dark text-white">
    <div class="max-w-7xl mx-auto">
      <p class="text-primary text-sm font-medium uppercase tracking-wider mb-4">
        {locale === "pt" ? "Contacto" : "Contact"}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold">{t.contact.title}</h1>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl font-bold text-dark mb-6">
            {locale === "pt" ? "Envie-nos uma mensagem" : "Send us a message"}
          </h2>
          <ContactForm client:load labels={t.contact} />
        </div>

        <div>
          <h2 class="text-2xl font-bold text-dark mb-6">
            {locale === "pt" ? "Informações" : "Information"}
          </h2>
          <div class="space-y-6">
            <div>
              <h3 class="text-sm font-medium text-primary uppercase tracking-wider mb-2">
                {locale === "pt" ? "Morada" : "Address"}
              </h3>
              <p class="text-gray-600">Rua da Arquitetura, 123, Lisboa</p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-primary uppercase tracking-wider mb-2">
                Email
              </h3>
              <p class="text-gray-600">info@arquitetura.pt</p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-primary uppercase tracking-wider mb-2">
                {locale === "pt" ? "Telefone" : "Phone"}
              </h3>
              <p class="text-gray-600">+351 21 123 4567</p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-primary uppercase tracking-wider mb-2">
                {locale === "pt" ? "Horário" : "Hours"}
              </h3>
              <p class="text-gray-600">
                {locale === "pt"
                  ? "Segunda a Sexta: 9h00 - 18h00"
                  : "Monday to Friday: 9am - 6pm"}
              </p>
            </div>
          </div>

          <div class="mt-12">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3113.4564!2d-9.1393!3d38.7223!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd19331a61e4f33b%3A0x400ebbde49036d0!2sLisbon%2C%20Portugal!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="rounded-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
