---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import HeroCarousel from "@/components/react/HeroCarousel";
import ContactForm from "@/components/react/ContactForm";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const heroImages = ["/images/carrosel/banner_01.png", "/images/carrosel/banner_02.png"];
---

<BaseLayout title="arqmag">
  <!-- HOME -->
  <section id="home" class="scroll-mt-0">
    <HeroCarousel client:load images={heroImages} />
  </section>

  <!-- SOBRE NÓS -->
  <section id="sobre" class="py-24 px-6 scroll-mt-20 bg-white">
    <div class="max-w-7xl mx-auto max-w-3xl">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-6">
        {t.about.label}
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-dark mb-8 leading-tight">
        {t.about.title}
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed mb-6">{t.about.p1}</p>
      <p class="text-gray-500 text-lg leading-relaxed">{t.about.p2}</p>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section id="servicos" class="scroll-mt-20">
    <!-- Bloco A: Imagem + texto + citação -->
    <div class="py-24 px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">
          {t.services.label}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-dark mb-12 max-w-lg">
          {t.services.title}
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="aspect-[4/3] overflow-hidden rounded-lg">
            <img
              src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800"
              alt="Arquitetura"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div>
            <p class="text-gray-500 leading-relaxed mb-8">{t.services.intro}</p>
            <ul class="space-y-0 mb-10">
              {[t.services.item1, t.services.item2, t.services.item3, t.services.item4].map((item) => (
                <li class="py-4 border-b border-gray-200 text-dark font-medium">{item}</li>
              ))}
            </ul>
            <div class="bg-primary p-6 rounded-sm">
              <p class="text-dark font-semibold text-lg leading-snug italic">
                "{t.services.quote}"
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bloco B: Fases (fundo escuro) -->
    <div
      class="relative py-24 px-6 bg-dark bg-cover bg-center"
      style="background-image: linear-gradient(rgba(26,26,26,0.88), rgba(26,26,26,0.88)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600');"
    >
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-gray-700">
          {[
            { label: t.phases.phase1Label, title: t.phases.phase1Title, desc: t.phases.phase1Desc },
            { label: t.phases.phase2Label, title: t.phases.phase2Title, desc: t.phases.phase2Desc },
            { label: t.phases.phase3Label, title: t.phases.phase3Title, desc: t.phases.phase3Desc },
          ].map((phase) => (
            <div class="px-8 py-10 first:pl-0 last:pr-0 group">
              <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">
                {phase.label}
              </p>
              <h3 class="text-2xl font-bold text-white mb-4">{phase.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-8">{phase.desc}</p>
              <div class="w-8 h-8 border border-primary rounded-full flex items-center justify-center text-primary text-xl leading-none">
                +
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bloco C: Os Nossos Serviços (fundo escuro) -->
    <div class="py-24 px-6 bg-dark">
      <div class="max-w-7xl mx-auto text-center">
        <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">
          {t.services.servicesLabel}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-16">
          {t.services.servicesTitle}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
          <!-- Projetos de Remodelação -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="2">
                <path d="M8 56V28L32 8l24 20v28H40V40H24v16z"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service1}</p>
          </div>
          <!-- Projetos de Arquitetura -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="2">
                <rect x="8" y="8" width="48" height="48" rx="2"/>
                <path d="M8 24h48M24 8v48"/>
                <path d="M32 32l8-8M32 32l-4 4"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service2}</p>
          </div>
          <!-- Legalização -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="2">
                <rect x="12" y="8" width="40" height="52" rx="2"/>
                <path d="M20 24h24M20 32h24M20 40h16"/>
                <circle cx="44" cy="44" r="10" fill="none"/>
                <path d="M40 44l3 3 5-5"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service3}</p>
          </div>
          <!-- Terrenos -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="2">
                <path d="M32 8c-8 0-14 6-14 14 0 10 14 26 14 26s14-16 14-26c0-8-6-14-14-14z"/>
                <circle cx="32" cy="22" r="4"/>
                <path d="M16 52h32"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service4}</p>
          </div>
        </div>
        <a
          href="#contato"
          class="inline-block px-10 py-3 border border-primary text-primary text-sm font-semibold uppercase tracking-widest hover:bg-primary hover:text-dark transition-colors rounded-sm"
        >
          {t.services.seeMore}
        </a>
      </div>
    </div>
  </section>

  <!-- PROJETOS -->
  <section id="projetos" class="scroll-mt-20">
    <div class="grid grid-cols-2 md:grid-cols-4">
      {[
        { src: "https://images.unsplash.com/photo-1499092346302-8d6bfea35eb1?w=800", city: "Hangzhou", country: "China" },
        { src: "https://images.unsplash.com/photo-1526312426976-5d6b15e7a31d?w=800", city: "Los Angeles", country: "United States" },
        { src: "https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800", city: "Montreal", country: "Canada" },
        { src: "https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=800", city: "Reggio Emilia", country: "Italy" },
      ].map((loc) => (
        <div class="relative h-64 md:h-96 overflow-hidden group">
          <img
            src={loc.src}
            alt={loc.city}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent" />
          <div class="absolute bottom-4 left-4">
            <p class="text-white text-xs uppercase tracking-widest">{loc.country}</p>
            <p class="text-white font-semibold">{loc.city}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contato" class="py-24 px-6 scroll-mt-20 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <div class="flex justify-center mb-6">
        <div class="flex gap-1">
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span class="w-2 h-2 rounded-full bg-gray-300"></span>
          <span class="w-2 h-2 rounded-full bg-gray-300"></span>
        </div>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-dark mb-4">{t.contact.title}</h2>
      <p class="text-gray-500 mb-12">{t.contact.subtitle}</p>
      <div class="text-left">
        <ContactForm client:load labels={t.contact} />
      </div>
    </div>
  </section>
</BaseLayout>
