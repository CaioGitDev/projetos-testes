---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLocaleFromUrl, useTranslations } from "@/i18n";
import HeroCarousel from "@/components/react/HeroCarousel";
import ContactForm from "@/components/react/ContactForm";

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const heroImages = ["/images/carrosel/banner_01.png", "/images/carrosel/banner_02.png"];
---

<BaseLayout title="arqmag">

  <!-- ── HOME (parallax hero) ─────────────────────────────────────── -->
  <section id="home" class="relative h-screen overflow-hidden scroll-mt-0">
    <div id="hero-parallax">
      <HeroCarousel client:load images={heroImages} />
    </div>
  </section>

  <!-- ── SOBRE NÓS ────────────────────────────────────────────────── -->
  <section id="sobre" class="py-28 px-6 scroll-mt-20 bg-white">
    <div class="max-w-7xl mx-auto max-w-3xl">
      <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-6"
         data-animate>
        {t.about.label}
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-dark mb-8 leading-tight"
          data-reveal>
        {t.about.title}
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed mb-6"
         data-animate style="transition-delay:100ms">
        {t.about.p1}
      </p>
      <p class="text-gray-500 text-lg leading-relaxed"
         data-animate style="transition-delay:200ms">
        {t.about.p2}
      </p>
    </div>
  </section>

  <!-- ── SERVIÇOS ──────────────────────────────────────────────────── -->
  <section id="servicos" class="scroll-mt-20">

    <!-- Bloco A: imagem + texto + citação -->
    <div class="py-28 px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4"
           data-animate>
          {t.services.label}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-dark mb-14 max-w-lg"
            data-reveal>
          {t.services.title}
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <div class="aspect-[4/3] overflow-hidden rounded-lg" data-animate>
            <img
              src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800"
              alt="Arquitetura"
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              loading="lazy"
            />
          </div>
          <div>
            <p class="text-gray-500 leading-relaxed mb-10" data-animate style="transition-delay:80ms">
              {t.services.intro}
            </p>
            <ul class="space-y-0 mb-10" data-stagger>
              <li class="py-4 border-b border-gray-200 text-dark font-medium">{t.services.item1}</li>
              <li class="py-4 border-b border-gray-200 text-dark font-medium">{t.services.item2}</li>
              <li class="py-4 border-b border-gray-200 text-dark font-medium">{t.services.item3}</li>
              <li class="py-4 border-b border-gray-200 text-dark font-medium">{t.services.item4}</li>
            </ul>
            <div class="bg-primary p-6 rounded-sm" data-animate style="transition-delay:200ms">
              <p class="text-dark font-semibold text-lg leading-snug italic">
                "{t.services.quote}"
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bloco B: Fases (fundo escuro) -->
    <div
      class="relative py-28 px-6"
      style="background-image: linear-gradient(rgba(26,26,26,0.9), rgba(26,26,26,0.9)), url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600'); background-size: cover; background-position: center;"
    >
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-700"
             data-stagger>
          {[
            { label: t.phases.phase1Label, title: t.phases.phase1Title, desc: t.phases.phase1Desc },
            { label: t.phases.phase2Label, title: t.phases.phase2Title, desc: t.phases.phase2Desc },
            { label: t.phases.phase3Label, title: t.phases.phase3Title, desc: t.phases.phase3Desc },
          ].map((phase) => (
            <div class="px-8 py-10 first:pl-0 last:pr-0">
              <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4">
                {phase.label}
              </p>
              <h3 class="text-2xl font-bold text-white mb-4">{phase.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-8">{phase.desc}</p>
              <div class="w-8 h-8 border border-primary rounded-full flex items-center justify-center text-primary text-xl leading-none hover:bg-primary hover:text-dark transition-colors cursor-default">
                +
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Bloco C: Os Nossos Serviços (fundo escuro) -->
    <div class="py-28 px-6 bg-dark">
      <div class="max-w-7xl mx-auto text-center">
        <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-4"
           data-animate>
          {t.services.servicesLabel}
        </p>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-16"
            data-reveal>
          {t.services.servicesTitle}
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-14" data-stagger>
          <!-- Projetos de Remodelação -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="1.5">
                <path d="M8 56V28L32 8l24 20v28H40V40H24v16z"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service1}</p>
          </div>
          <!-- Projetos de Arquitetura -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="1.5">
                <rect x="8" y="8" width="48" height="48" rx="2"/>
                <path d="M8 24h48M24 8v48M36 32l8-8M36 32l-4 4"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service2}</p>
          </div>
          <!-- Legalização -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="1.5">
                <rect x="12" y="8" width="40" height="52" rx="2"/>
                <path d="M20 24h24M20 33h24M20 42h14"/>
                <path d="M38 42l4 4 7-7" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service3}</p>
          </div>
          <!-- Terrenos -->
          <div class="flex flex-col items-center gap-4">
            <div class="w-16 h-16 flex items-center justify-center">
              <svg viewBox="0 0 64 64" fill="none" class="w-12 h-12 text-primary" stroke="currentColor" stroke-width="1.5">
                <path d="M32 8c-8.8 0-16 7.2-16 16 0 11 16 28 16 28s16-17 16-28c0-8.8-7.2-16-16-16z"/>
                <circle cx="32" cy="24" r="5"/>
                <path d="M14 54h36" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="text-white text-sm font-medium text-center">{t.services.service4}</p>
          </div>
        </div>
        <a
          href="#contato"
          class="inline-block px-10 py-3 border border-primary text-primary text-xs font-semibold uppercase tracking-widest hover:bg-primary hover:text-dark transition-colors rounded-sm"
          data-animate
        >
          {t.services.seeMore}
        </a>
      </div>
    </div>
  </section>

  <!-- ── PROJETOS ──────────────────────────────────────────────────── -->
  <section id="projetos" class="scroll-mt-20">
    <div class="grid grid-cols-2 md:grid-cols-4" data-stagger>
      {[
        { src: "https://images.unsplash.com/photo-1499092346302-8d6bfea35eb1?w=800", city: "Hangzhou", country: "China" },
        { src: "https://images.unsplash.com/photo-1526312426976-5d6b15e7a31d?w=800", city: "Los Angeles", country: "United States" },
        { src: "https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=800", city: "Montreal", country: "Canada" },
        { src: "https://images.unsplash.com/photo-1555400038-63f5ba517a47?w=800", city: "Reggio Emilia", country: "Italy" },
      ].map((loc) => (
        <div class="gallery-item h-64 md:h-96">
          <img src={loc.src} alt={loc.city} loading="lazy" class="w-full h-full object-cover" />
          <div class="gallery-overlay" />
          <div class="gallery-label">
            <p class="gallery-country">{loc.country}</p>
            <p class="gallery-city">{loc.city}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── CONTACTO ──────────────────────────────────────────────────── -->
  <section id="contato" class="py-28 px-6 scroll-mt-20 bg-white">
    <div class="max-w-2xl mx-auto text-center">
      <div class="flex justify-center mb-8" data-animate>
        <div class="flex gap-1.5">
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span class="w-2 h-2 rounded-full bg-gray-200"></span>
          <span class="w-2 h-2 rounded-full bg-gray-200"></span>
        </div>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-dark mb-4"
          data-reveal>
        {t.contact.title}
      </h2>
      <p class="text-gray-500 mb-14" data-animate style="transition-delay:150ms">
        {t.contact.subtitle}
      </p>
      <div class="text-left" data-animate style="transition-delay:250ms">
        <ContactForm client:load labels={t.contact} />
      </div>
    </div>
  </section>

</BaseLayout>
